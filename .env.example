# Blog AI Agent — 환경변수 템플릿
# 이 파일을 .env로 복사한 후 값을 채워 사용
# .env는 .gitignore에 포함 (절대 커밋하지 않음)

# ──────────────────────────────────────────
# 서버 설정
# ──────────────────────────────────────────
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
FRONTEND_PORT=5173

# ──────────────────────────────────────────
# Tistory 배포 (Playwright 반자동)
# ──────────────────────────────────────────
# 카카오 OAuth 자동화 금지 — 사용자 수동 로그인 필수
# 로그인 정보를 환경변수에도 저장 금지
TISTORY_BLOG_URL=https://jaylenhan.tistory.com

# ──────────────────────────────────────────
# Claude Code CLI
# ──────────────────────────────────────────
# Claude Max 구독으로 동작 — 별도 API 키 불필요
# 백엔드가 subprocess로 Claude Code CLI를 호출
CLAUDE_CODE_PATH=claude

# ──────────────────────────────────────────
# 로깅
# ──────────────────────────────────────────
LOG_LEVEL=INFO
