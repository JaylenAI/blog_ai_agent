# Backend
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
FRONTEND_PORT=5173

# Database (SQLite)
DATABASE_URL=sqlite+aiosqlite:///./data/blog.db

# Claude Code CLI
CLAUDE_CODE_PATH=claude

# Tistory
TISTORY_BLOG_URL=https://jaylenhan.tistory.com

# Obsidian vault (비어 있으면 Obsidian 저장 비활성화)
OBSIDIAN_VAULT_PATH=

# 작업 디렉토리
SISYPHUS_DIR=.sisyphus

# Logging
LOG_LEVEL=INFO

# Stage 타임아웃 (초)
STAGE_TIMEOUT=600
